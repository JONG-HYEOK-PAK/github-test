    print("현재 비교는 P&O vs P&O (샘플링 시간만 다름)")
    print("따라서 차이는 알고리즘 종류가 아니라 dt 차이로 해석")
    print(f"DELTA_V = {DELTA_V:.2f} V")
    print("업데이트 주파수 = 1 / dt")
    print("유효 perturb 속도 = DELTA_V / dt")

    for label, h in history.items():
        t = np.array(h["time"])
        v = np.array(h["v_pv"])
        i = np.array(h["i_pv"])
        p = np.array(h["p_pv"])
        pref = np.array(h["p_mpp"])
        dt = 0.01 if label == "dt=0.01s" else 0.05

        print("\n" + "-" * 82)
        print(label)
        print("-" * 82)
        print(f"Control dt                                : {dt:.4f} s")
        print(f"Update frequency 1/dt                     : {1.0/dt:.2f} Hz")
        print(f"Effective perturb rate DELTA_V/dt         : {DELTA_V/dt:.2f} V/s")
        print(f"Initial reach time to ±{SETTLING_BAND*100:.1f}% of 250 W : "
              f"{first_reach_time_to_band(t, p, P_MAX, tol=SETTLING_BAND):.4f} s")
        print(f"Settling time after 3 s transition        : "
              f"{find_settling_time(t, p, pref, 3.0, tol=SETTLING_BAND, hold_time=SETTLING_HOLD):.4f} s")
        print(f"Settling time after 6 s transition        : "
              f"{find_settling_time(t, p, pref, 6.0, tol=SETTLING_BAND, hold_time=SETTLING_HOLD):.4f} s")

        print("\nRipple (peak-to-peak)")
        for name, t0, t1 in RIPPLE_WINDOWS:
            mask = (t >= t0) & (t <= t1)
            print(f"  {name:<12} "
                  f"Vpp={peak_to_peak(v[mask]):.4f} V, "
                  f"Ipp={peak_to_peak(i[mask]):.4f} A, "
                  f"Ppp={peak_to_peak(p[mask]):.4f} W")


# ============================================================
# 10. 메인 실행
# ============================================================
def main():
    time_arr = np.arange(0.0, T_END + MASTER_DT * 0.5, MASTER_DT)

    cases = {
        "dt=0.01s": POCase(0.01, "dt=0.01s"),
        "dt=0.05s": POCase(0.05, "dt=0.05s"),
    }

    history = {}
    for label in cases:
        history[label] = {
            "time": [],
            "irradiance": [],
            "v_pv": [],
            "v_ref": [],
            "i_pv": [],
            "i_mpp": [],
            "p_pv": [],
            "p_mpp": [],
            "p_err": [],
            "efficiency": [],
        }

    dash = setup_live_dashboard()
    plt.show(block=False)

    wall_prev = time.perf_counter()

    for k, t in enumerate(time_arr):
        irr = irradiance(float(t))

        for label, case in cases.items():
            out = case.step(float(t), irr, MASTER_DT)

            history[label]["time"].append(float(t))
            history[label]["irradiance"].append(float(irr))
            history[label]["v_pv"].append(float(out["v_pv"]))
            history[label]["v_ref"].append(float(out["v_ref"]))
            history[label]["i_pv"].append(float(out["i_pv"]))
            history[label]["i_mpp"].append(float(out["i_mpp"]))
            history[label]["p_pv"].append(float(out["p_pv"]))
            history[label]["p_mpp"].append(float(out["p_mpp"]))
            history[label]["p_err"].append(float(out["p_err"]))
            history[label]["efficiency"].append(float(out["eff"]))

        if k % LIVE_UPDATE_EVERY == 0 or k == len(time_arr) - 1:
            update_live_dashboard(dash, history, k)

        if REALTIME_PLAYBACK and k < len(time_arr) - 1:
            target = MASTER_DT / max(PLAYBACK_SPEED, 1e-12)
            now = time.perf_counter()
            elapsed = now - wall_prev
            if elapsed < target:
                time.sleep(target - elapsed)
            wall_prev = time.perf_counter()

    print_report(history)

    plt.ioff()
    plt.show()


if __name__ == "__main__":
    main()
