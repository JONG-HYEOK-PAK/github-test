def style_axis(ax, y_label=None, x_label=None, x_major=1.0, x_minor=0.2):
    if y_label is not None:
        ax.set_ylabel(y_label, fontsize=10)
    if x_label is not None:
        ax.set_xlabel(x_label, fontsize=10)

    ax.grid(True, which="major", linewidth=0.8, alpha=0.85)
    ax.grid(True, which="minor", linewidth=0.35, alpha=0.45)
    ax.minorticks_on()
    ax.xaxis.set_major_locator(MultipleLocator(x_major))
    ax.xaxis.set_minor_locator(MultipleLocator(x_minor))


def add_cursor(ax, color="crimson"):
    return ax.axvline(0.0, color=color, linestyle="-", linewidth=1.0, alpha=0.8)


def set_cursor(cursor_line, x):
    cursor_line.set_xdata([x, x])


def adaptive_error_ylim(ax, y1, y2, margin=0.12, min_half_range=0.35, max_half_range=2.0):
    vals = np.concatenate([y1, y2]) if len(y1) and len(y2) else np.array([0.0])
    max_abs = np.max(np.abs(vals)) if vals.size > 0 else 0.0
    half = min(max(max_abs + margin, min_half_range), max_half_range)
    ax.set_ylim(-half, half)


