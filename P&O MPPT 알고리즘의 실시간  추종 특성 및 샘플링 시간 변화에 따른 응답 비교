def update_live_dashboard(dash, history, k):
    lines = dash["lines"]

    r01 = history["dt=0.01s"]
    r05 = history["dt=0.05s"]

    t = np.array(r01["time"][:k+1])

    irr = np.array(r01["irradiance"][:k+1])

    r01_vpv = np.array(r01["v_pv"][:k+1])
    r01_vr  = np.array(r01["v_ref"][:k+1])
    r01_ipv = np.array(r01["i_pv"][:k+1])
    r01_impp = np.array(r01["i_mpp"][:k+1])
    r01_ppv = np.array(r01["p_pv"][:k+1])
    r01_pmpp = np.array(r01["p_mpp"][:k+1])
    r01_perr = np.array(r01["p_err"][:k+1])
    r01_eff = np.array(r01["efficiency"][:k+1])

    r05_vpv = np.array(r05["v_pv"][:k+1])
    r05_vr  = np.array(r05["v_ref"][:k+1])
    r05_ipv = np.array(r05["i_pv"][:k+1])
    r05_ppv = np.array(r05["p_pv"][:k+1])
    r05_perr = np.array(r05["p_err"][:k+1])
    r05_eff = np.array(r05["efficiency"][:k+1])

    # Overview
    lines["irr"].set_data(t, irr)

    lines["v01"].set_data(t, r01_vpv)
    lines["vr01"].set_data(t, r01_vr)
    lines["v05"].set_data(t, r05_vpv)
    lines["vr05"].set_data(t, r05_vr)

    lines["i01"].set_data(t, r01_ipv)
    lines["i05"].set_data(t, r05_ipv)
    lines["impp"].set_data(t, r01_impp)

    lines["p01"].set_data(t, r01_ppv)
    lines["p05"].set_data(t, r05_ppv)
    lines["pmpp"].set_data(t, r01_pmpp)

    lines["e01"].set_data(t, r01_eff)
    lines["e05"].set_data(t, r05_eff)

    # Zoom around 3s
    mask3 = (t >= 3.0 - ZOOM_HALF_WINDOW) & (t <= 3.0 + ZOOM_HALF_WINDOW)

    lines["z3_v01"].set_data(t[mask3], r01_vpv[mask3])
    lines["z3_v05"].set_data(t[mask3], r05_vpv[mask3])

    lines["z3_i01"].set_data(t[mask3], r01_ipv[mask3])
    lines["z3_i05"].set_data(t[mask3], r05_ipv[mask3])
    lines["z3_impp"].set_data(t[mask3], r01_impp[mask3])

    lines["z3_p01"].set_data(t[mask3], r01_ppv[mask3])
    lines["z3_p05"].set_data(t[mask3], r05_ppv[mask3])
    lines["z3_pmpp"].set_data(t[mask3], r01_pmpp[mask3])

    lines["z3_err01"].set_data(t[mask3], r01_perr[mask3])
    lines["z3_err05"].set_data(t[mask3], r05_perr[mask3])

    adaptive_error_ylim(
        dash["ax_z3_err"],
        r01_perr[mask3],
        r05_perr[mask3],
        margin=0.12,
        min_half_range=0.35,
        max_half_range=2.0
    )

    # Zoom around 6s
    mask6 = (t >= 6.0 - ZOOM_HALF_WINDOW) & (t <= 6.0 + ZOOM_HALF_WINDOW)

    lines["z6_v01"].set_data(t[mask6], r01_vpv[mask6])
    lines["z6_v05"].set_data(t[mask6], r05_vpv[mask6])

    lines["z6_i01"].set_data(t[mask6], r01_ipv[mask6])
    lines["z6_i05"].set_data(t[mask6], r05_ipv[mask6])
    lines["z6_impp"].set_data(t[mask6], r01_impp[mask6])

    lines["z6_p01"].set_data(t[mask6], r01_ppv[mask6])
    lines["z6_p05"].set_data(t[mask6], r05_ppv[mask6])
    lines["z6_pmpp"].set_data(t[mask6], r01_pmpp[mask6])

    lines["z6_err01"].set_data(t[mask6], r01_perr[mask6])
    lines["z6_err05"].set_data(t[mask6], r05_perr[mask6])

    adaptive_error_ylim(
        dash["ax_z6_err"],
        r01_perr[mask6],
        r05_perr[mask6],
        margin=0.12,
        min_half_range=0.35,
        max_half_range=2.0
    )

    # 현재 시간 커서
    t_cur = t[-1]
    for cursor in dash["cursors"]:
        set_cursor(cursor, t_cur)

    dash["fig"].canvas.draw_idle()
    dash["fig"].canvas.flush_events()
    plt.pause(0.001)


