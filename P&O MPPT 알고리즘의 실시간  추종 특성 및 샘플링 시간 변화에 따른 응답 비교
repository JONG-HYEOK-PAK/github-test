def peak_to_peak(x):
    x = np.asarray(x)
    return float(np.max(x) - np.min(x)) if x.size > 0 else float("nan")


def first_reach_time_to_band(t, y, y_ref_scalar, tol=0.02):
    t = np.asarray(t)
    y = np.asarray(y)
    ref_abs = max(abs(y_ref_scalar), 1e-12)
    err = np.abs(y - y_ref_scalar) / ref_abs
    idx = np.where(err <= tol)[0]
    return float(t[idx[0]]) if len(idx) > 0 else np.nan


def find_settling_time(t, y, y_ref, start_time, tol=0.02, hold_time=0.15):
    t = np.asarray(t)
    y = np.asarray(y)
    y_ref = np.asarray(y_ref)

    start_idx = np.searchsorted(t, start_time, side="left")
    if start_idx >= len(t):
        return np.nan

    ref_abs = np.maximum(np.abs(y_ref), 1e-12)
    err = np.abs(y - y_ref) / ref_abs
    hold_samples = max(1, int(np.ceil(hold_time / (t[1] - t[0]))))

    for i in range(start_idx, len(t) - hold_samples + 1):
        if np.all(err[i:i + hold_samples] <= tol):
            return float(t[i] - start_time)

    return np.nan


